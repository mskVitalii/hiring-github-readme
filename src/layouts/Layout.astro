---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Hiring GitHub Readme — Developer Skills Scanner',
  description = 'Scan any GitHub profile to extract developer skills and technologies. Perfect for HR and recruiters.',
} = Astro.props;

const base = import.meta.env.BASE_URL || '/';
const isProduction = import.meta.env.PROD;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(`${base}og-image.png`, Astro.site);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Hiring GitHub Readme',
  description,
  url: canonicalURL.toString(),
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  author: {
    '@type': 'Person',
    name: 'Vitalii Popov',
    url: 'https://www.linkedin.com/in/mskvitalii/',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0d1117" />
    <meta name="author" content="Vitalii Popov" />
    <meta name="keywords" content="github, developer skills, hiring, recruiter, HR, tech stack, portfolio, resume" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Hiring GitHub Readme" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" sizes="192x192" href={`${base}favicon-192.png`} />
    <link rel="icon" type="image/png" sizes="512x512" href={`${base}favicon-512.png`} />
    <link rel="apple-touch-icon" href={`${base}favicon-192.png`} />

    <title>{title}</title>

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <!-- Google Analytics -->
    {import.meta.env.PUBLIC_GA_ID && (
      <script define:vars={{ gaId: import.meta.env.PUBLIC_GA_ID }}>
        window.dataLayer = window.dataLayer || [];
        window.gtag = window.gtag || function () {
          window.dataLayer.push(arguments);
        };

        const consentKey = 'ga_consent';
        const analyticsSrc = `https://www.googletagmanager.com/gtag/js?id=${gaId}`;
        let isConfigured = false;
        let hasRequestedScript = false;

        function gtag() {
          window.gtag(...arguments);
        }

        function ensureAnalyticsScript() {
          if (hasRequestedScript) return;
          hasRequestedScript = true;

          const script = document.createElement('script');
          script.async = true;
          script.src = analyticsSrc;
          document.head.appendChild(script);

          gtag('js', new Date());
        }

        function configureAnalytics() {
          if (isConfigured) return;
          gtag('config', gaId, { send_page_view: false });
          isConfigured = true;
        }

        function updateConsent(value) {
          gtag('consent', 'update', {
            ad_storage: 'denied',
            ad_user_data: 'denied',
            ad_personalization: 'denied',
            analytics_storage: value,
          });
        }

        function expireCookie(name, domain) {
          const domainPart = domain ? `;domain=${domain}` : '';
          document.cookie = `${name}=;expires=Thu, 01 Jan 1970 00:00:00 GMT;max-age=0;path=/${domainPart}`;
        }

        function clearGaCookies() {
          const cookieNames = document.cookie
            .split(';')
            .map((item) => item.trim().split('=')[0])
            .filter(Boolean)
            .filter(
              (name) =>
                name === '_gid' ||
                name === '_gat' ||
                name.startsWith('_ga') ||
                name.startsWith('_gac_'),
            );

          if (!cookieNames.length) return;

          const host = window.location.hostname;
          const hostParts = host.split('.');
          const domainCandidates = [''];

          if (hostParts.length >= 2) {
            domainCandidates.push(host);
            for (let i = 0; i <= hostParts.length - 2; i += 1) {
              domainCandidates.push(`.${hostParts.slice(i).join('.')}`);
            }
          }

          cookieNames.forEach((name) => {
            domainCandidates.forEach((domain) => expireCookie(name, domain));
          });
        }

        function sendInitialPageView() {
          gtag('event', 'page_view', {
            page_location: window.location.href,
            page_path: window.location.pathname,
            page_title: document.title,
          });
        }

        function setAnalyticsConsent(granted) {
          const value = granted ? 'granted' : 'denied';
          localStorage.setItem(consentKey, value);

          if (granted) {
            ensureAnalyticsScript();
            configureAnalytics();
          }

          updateConsent(value);

          if (!granted) {
            clearGaCookies();
            return;
          }

          sendInitialPageView();
        }

        window.setAnalyticsConsent = setAnalyticsConsent;

        gtag('consent', 'default', {
          ad_storage: 'denied',
          ad_user_data: 'denied',
          ad_personalization: 'denied',
          analytics_storage: 'denied',
        });

        if (localStorage.getItem(consentKey) === 'granted') {
          ensureAnalyticsScript();
          configureAnalytics();
          updateConsent('granted');
          sendInitialPageView();
        }
      </script>
    )}

    {isProduction && (
      <script define:vars={{ base }}>
        window.va = window.va || function () {
          window.vaq = window.vaq || [];
          window.vaq.push(arguments);
        };

        window.si = window.si || function () {
          window.siq = window.siq || [];
          window.siq.push(arguments);
        };

        function normalizePath(path) {
          return path.replace(/\/+/g, '/');
        }

        function injectScript(src, dataset) {
          if (document.head.querySelector(`script[src="${src}"]`)) return;

          const script = document.createElement('script');
          script.src = src;
          script.defer = true;

          Object.entries(dataset).forEach(([key, value]) => {
            script.dataset[key] = value;
          });

          document.head.appendChild(script);
        }

        function loadVercelInsights() {
          const basePath = normalizePath(base || '/');
          const analyticsScript = normalizePath(`${basePath}_vercel/insights/script.js`);
          const speedInsightsScript = normalizePath(`${basePath}_vercel/speed-insights/script.js`);
          const currentPath = window.location.pathname;

          injectScript(analyticsScript, {
            sdkn: '@vercel/analytics/custom',
            sdkv: '2.0.1',
          });

          injectScript(speedInsightsScript, {
            sdkn: '@vercel/speed-insights/custom',
            sdkv: '2.0.0',
          });

          window.va('pageview', {
            route: currentPath,
            path: currentPath,
          });
        }

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadVercelInsights, { timeout: 2500 });
        } else {
          window.setTimeout(loadVercelInsights, 1500);
        }
      </script>
    )}
  </head>
  <body class="min-h-screen bg-gh-bg text-gh-text" data-base-url={base}>
    <slot />
  </body>
</html>
