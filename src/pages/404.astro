---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL || '/';
---

<Layout title="404 — Page Not Found" description="This page doesn't exist.">
  <script is:inline>
    (() => {
      const bodyElement = document.querySelector('body');
      const base = bodyElement?.getAttribute('data-base-url') || '/';
      const { pathname, search, hash } = window.location;
      const relative = pathname.startsWith(base) ? pathname.slice(base.length) : pathname;
      const firstSegment = relative.split('/').filter(Boolean)[0] ?? '';

      if (!firstSegment) return;

      const params = new URLSearchParams(search);
      if (!params.has('u')) {
        params.set('u', firstSegment);
      }

      const query = params.toString();
      const target = `${base}${query ? `?${query}` : ''}${hash}`.replace(/\/+/g, '/');
      window.location.replace(target);
    })();
  </script>

  <main class="min-h-screen flex flex-col items-center justify-center px-4 text-center">
    <h1 class="text-6xl font-bold text-gh-accent mb-4">404</h1>
    <p class="text-xl text-gh-text mb-2">Page not found</p>
    <p class="text-gh-text-secondary mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a
      href={`${base}?`}
      class="px-6 py-3 rounded-lg bg-gh-green text-gh-bg font-semibold hover:opacity-90 transition-opacity"
    >
      Go to Scanner
    </a>
  </main>
</Layout>
