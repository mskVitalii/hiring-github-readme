---
import App from '../components/App';
import Layout from '../layouts/Layout.astro';

interface GitHubUser {
  login: string;
  name: string | null;
  bio: string | null;
}

const rawUsername = decodeURIComponent(Astro.params.username ?? '').trim();
const isValidUsername = /^[a-z\d](?:[a-z\d]|-(?=[a-z\d])){0,38}$/i.test(rawUsername);

let user: GitHubUser | null = null;

if (isValidUsername) {
  try {
    const response = await fetch(`https://api.github.com/users/${rawUsername}`, {
      headers: {
        Accept: 'application/vnd.github+json',
        'User-Agent': 'hiring-github-readme',
      },
    });

    if (response.ok) {
      user = (await response.json()) as GitHubUser;
    } else if (response.status === 404) {
      Astro.response.status = 404;
    }
  } catch {
    // Keep default SEO metadata if GitHub API is unavailable.
  }
} else {
  Astro.response.status = 404;
}

const displayName = user?.name?.trim() || user?.login || rawUsername;
const title = `${displayName} - GitHub Skills Scanner`;
const baseDescription = user?.bio?.trim()
  ? `${displayName}: ${user.bio}`
  : `Open ${displayName} in Hiring GitHub Readme to scan public repositories and generate a recruiter-ready skills summary.`;

const descriptionSuffix =
  ' Analyze languages, frameworks, and tooling from public repositories to create a concise hiring profile for recruiters.';

const description =
  baseDescription.length >= 100
    ? baseDescription
    : `${baseDescription}${descriptionSuffix}`;
---

<Layout title={title} description={description}>
  <script is:inline>
    const bodyElement = document.querySelector('body');
    window.__BASE_URL__ = bodyElement?.getAttribute('data-base-url') || '/';
  </script>
  <App client:idle />
</Layout>
